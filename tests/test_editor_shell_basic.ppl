test_editor_shell_basic;
#pragma mode( separator(.,;) integer(h32) )

// ================================================================
// Editor Shell Test Harness  (Task 6)
//
// REQUIRES: all 4 modules loaded in order:
//   1. hebrew_font_bitmap
//   2. text_engine
//   3. renderer
//   4. editor_shell
//
// ENTRY POINTS:
//   test_editor_shell_basic()  -- blank document, verify S1
//   editor_shell_demo()        -- pre-loaded document, verify S2-S9
//
// MANUAL VERIFICATION SCENARIOS:
//
// S1: Shell launch
//   - Run test_editor_shell_basic()
//   - Expected: dark header, editor area, keyboard panel visible
//   - Expected: blue cursor at top-left of editor area
//   - Expected: [HEB] indicator in header (green)
//   - No immediate crash or close
//
// S2: Cursor movement
//   - Tap < > ^ v keys in control row
//   - Expected: cursor moves left/right/up/down
//   - Expected: viewport stays stable on empty doc (no scroll)
//
// S3: Hebrew character insertion
//   - Tap any letter key in Hebrew rows
//   - Expected: Hebrew glyph appears in editor (RTL from right)
//   - Expected: cursor advances left (RTL)
//
// S4: Newline
//   - Tap ENT in control row
//   - Expected: new line created, cursor moves to line 2 col 1
//   - Expected: line count increases
//
// S5: Backspace
//   - Insert a few chars, then tap BS
//   - Expected: last char deleted, cursor moves left
//   - Expected: at line start with multiple lines, merges with previous
//
// S6: Layout switching
//   - Tap LAY in control row
//   - Expected: header changes from [HEB] to [CTL]
//   - Expected: letter rows show digits/punctuation instead of glyphs
//   - Tap LAY again: returns to [HEB]
//
// S7: Keyboard hide/show
//   - Tap KBD in control row
//   - Expected: keyboard panel disappears, editor expands to 9 lines
//   - Tap KBD again (now at bottom of screen area or hardware key)
//   Note: when keyboard hidden, KBD button is not visible.
//   To re-show: call editor_shell_demo() again or press hardware ESC.
//   (Full KBD toggle via hardware key is a deferred feature.)
//
// S8: Viewport adjustment
//   - Run editor_shell_demo() (has 6 pre-loaded lines)
//   - Tap v (down) repeatedly until cursor passes line 4
//   - Expected: R_VIEW_TOP adjusts so cursor stays visible
//   - Expected: header shows document scrolled
//
// S9: Hebrew rendering through full path
//   - Run editor_shell_demo(), navigate to line 2 (Hebrew line)
//   - Expected: glyphs visible via text_engine -> renderer -> HFB path
//   - Tap more Hebrew keys: new glyphs appear
//
// EXIT: Press hardware ESC/Back key (code 4) to exit the shell.
// ================================================================


// ----------------------------------------------------------------
// editor_shell_demo -- pre-loaded 6-line document
// Line 1: LTR English
// Line 2: RTL Hebrew (shalom)
// Line 3: RTL Hebrew (bereshit)
// Line 4: LTR digits/mixed
// Line 5: empty line
// Line 6: LTR text
// ----------------------------------------------------------------
EXPORT editor_shell_demo()
BEGIN
  LOCAL h1, h2, doc;
  h1  := CHAR(1513)+CHAR(1500)+CHAR(1493)+CHAR(1501);
  h2  := CHAR(1489)+CHAR(1512)+CHAR(1488)+CHAR(1513)+CHAR(1497)+CHAR(1514);
  doc := {"Hello World", h1, h2, "Testing 123", "", "More text here"};
  editor_shell_from(doc);
END;


// ----------------------------------------------------------------
// test_editor_shell_basic -- blank document entry point
// Verifies S1: shell launches with empty doc, cursor visible
// ----------------------------------------------------------------
EXPORT test_editor_shell_basic()
BEGIN
  editor_shell();
END;
